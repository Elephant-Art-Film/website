---
import iconBars from '../icons/bars.svg?raw';
import iconXmark from '../icons/xmark.svg?raw';

import iconInstagram from '../icons/instagram.svg?raw';
import iconYoutube from '../icons/youtube.svg?raw';
import iconTwitter from '../icons/twitter.svg?raw';
import iconFacebook from '../icons/facebook.svg?raw';
import iconMail from '../icons/email.svg?raw';
import iconRSS from '../icons/rss.svg?raw';

interface Props {
	title: string;
	description: string;
	showLogo?: boolean;
}

const { title, description, showLogo = false } = Astro.props;

const currentYear = new Date().getFullYear();

const pathname = Astro.url.pathname;
const isActive = (path: string) =>
	path === '/' ? pathname === '/' : pathname.startsWith(path);
---

<!doctype html>
<html lang="en" class="text-gray-300 bg-zinc-800">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="shortcut icon" type="image/x-icon" href="favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5" />
		<meta name="msapplication-TileColor" content="#da532c" />
		<meta name="theme-color" content="#ffffff" />

		<title>{title}</title>
		<meta name="description" content={description} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Manrope:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<style is:global>
		/* Default site font (UI, navigation, headings) */
		html, body {
			font-family: Montserrat, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
		}

		/* Film long-form content (description, awards, credits, Q&A) */
		#film-content {
			font-family: Manrope, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
		}
		</style>


	</head>
	<body>
		<header
			id="menu"
			class="-translate-x-full xl:translate-x-0 xl:flex flex-col h-screen fixed top-0 left-0 z-10 xl:w-1/4 2xl:w-1/3 p-8 2xl:p-16 bg-black bg-blend-saturation duration-500 xl:duration-0"
		>
			<div
				id="menu-close"
				class="xl:hidden absolute left-0 top-0 fill-gray-300 hover:fill-gray-100 w-6 m-4 cursor-pointer"
			>
				<Fragment set:html={iconXmark} />
			</div>

			<!-- Logo + Nav: centered in remaining space -->
			<div class="flex-1 flex flex-col justify-center">
				<a href="/" class="block">
					<img
						src="/assets/brand/elephant-official-square.webp"
						alt="ELEPHANT art film productions"
						class="rounded-full w-48 xl:w-56 mx-auto"
					/>
				</a>
				<nav class="w-full mt-10">
					{[
						{ href: '/', label: 'HOME' },
						{ href: '/films', label: 'FILMS' },
						{ href: '/news', label: 'NEWS' },
						{ href: '/about', label: 'ABOUT US' },
					].map(({ href, label }) => (
						<a
							href={href}
							class={`flex items-center justify-center gap-3 py-4 text-xl xl:text-2xl tracking-widest uppercase font-light border-b border-zinc-900 transition-colors duration-200 group ${
								isActive(href)
									? 'text-white'
									: 'text-zinc-500 hover:text-zinc-200'
							}`}
						>
							{isActive(href) && (
								<span class="w-4 h-px bg-white inline-block shrink-0" />
							)}
							{label}
							{isActive(href) && (
								<span class="w-4 h-px bg-white inline-block shrink-0" />
							)}
						</a>
					))}
				</nav>
			</div>

			<!-- Social icons pinned to bottom -->
			<div class="flex w-full pb-2 justify-center gap-4 fill-zinc-500">
				<a href="https://www.instagram.com/elephantartfilm" target="_blank" class="w-5 hover:fill-white transition-colors duration-200" aria-label="Instagram">
					<Fragment set:html={iconInstagram} />
				</a>
				<a href="https://www.youtube.com/@elephantartfilm" target="_blank" class="w-5 hover:fill-white transition-colors duration-200" aria-label="Youtube">
					<Fragment set:html={iconYoutube} />
				</a>
				<a href="https://twitter.com/ElephantArtFilm" target="_blank" class="w-5 hover:fill-white transition-colors duration-200" aria-label="Twitter">
					<Fragment set:html={iconTwitter} />
				</a>
				<a href="https://www.facebook.com/profile.php?id=100089908492635" target="_blank" class="w-5 hover:fill-white transition-colors duration-200" aria-label="Facebook">
					<Fragment set:html={iconFacebook} />
				</a>
				<a href="mailto:elephantartfilm@gmail.com" target="_blank" class="w-5 hover:fill-white transition-colors duration-200" aria-label="Email">
					<Fragment set:html={iconMail} />
				</a>
				<a href="/news/feed.xml" target="_blank" class="w-4 hover:fill-white transition-colors duration-200" aria-label="RSS">
					<Fragment set:html={iconRSS} />
				</a>
			</div>
		</header>

		<div class="flex flex-col h-screen xl:ml-1/4 2xl:ml-1/3">
			<div class="xl:hidden grid grid-cols-3 items-center px-5 py-3 bg-black border-b border-zinc-800">
				<div></div>
				<a href="/" class="flex justify-center">
					<img
						src="/assets/brand/elephant-official-square.webp"
						alt="ELEPHANT art film productions"
						class="rounded-full w-10 h-10 object-cover"
					/>
				</a>
				<div class="flex justify-end">
					<div
						id="menu-open"
						class="fill-zinc-400 hover:fill-zinc-100 w-5 cursor-pointer transition-colors"
					>
						<Fragment set:html={iconBars} />
					</div>
				</div>
			</div>
			<main class="m-12 mt-8 xl:mt-16 2xl:mx-48">
				<slot />
			</main>
			<footer class="mt-auto border-t border-zinc-800 py-8 px-6">
				<p class="text-center text-xs tracking-widest uppercase text-zinc-500">
					&copy; 2019&ndash;{currentYear} ELEPHANT art film production.<br class="sm:hidden" /><span class="hidden sm:inline">&ensp;</span>All rights reserved.
				</p>
			</footer>
		</div>
	</body>
</html>

<script>
	document.getElementById('menu-open')?.addEventListener('click', () => {
		document.getElementById('menu')?.classList.toggle('-translate-x-full');
	});

	document.getElementById('menu-close')?.addEventListener('click', () => {
		document.getElementById('menu')?.classList.add('-translate-x-full');
	});
</script>
