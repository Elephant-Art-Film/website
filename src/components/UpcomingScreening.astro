---
interface Props {
  location: string;
  datetime: string;
  program?: string;
}

const { location, datetime, program } = Astro.props;
---

<div class="screening-card my-8">
  <div class="screening-icon">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
    </svg>
  </div>
  <div class="screening-info">
    <div class="screening-label">Upcoming Screening</div>
    {program && <div class="screening-program">{program}</div>}
    <div class="screening-datetime">{datetime}</div>
    <div class="screening-location">{location}</div>
  </div>
</div>

<style>
.screening-card {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  padding: 18px 24px;
  border-radius: 14px;
  background: rgba(18, 18, 18, 0.86);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
  
  /* Adds a subtle entry animation if needed, but styling matches existing components */
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.screening-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.45);
  border-color: rgba(255, 255, 255, 0.15);
}

.screening-icon {
  color: rgba(255, 255, 255, 0.82);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12px;
}

.screening-icon svg {
  width: 24px;
  height: 24px;
}

.screening-info {
  display: flex;
  flex-direction: column;
}

.screening-label {
  font-size: 0.85rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: rgba(255, 255, 255, 0.50);
  margin-bottom: 4px;
}

.screening-program {
  font-size: 1.05rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.88);
  margin-bottom: 3px;
  line-height: 1.4;
}

.screening-datetime {
  font-size: 1.15rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.98);
  line-height: 1.4;
}

.screening-location {
  font-size: 0.95rem;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.72);
  margin-top: 2px;
}

@media (max-width: 640px) {
  .screening-card {
    flex-direction: column;
    align-items: flex-start;
    padding: 16px 20px;
    gap: 1rem;
  }
}
</style>
