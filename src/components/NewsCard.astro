---
interface Props {
	title: string;
	slug: string;
	publishDate: Date;
	image: {
		src: string;
		alt: string;
	};
	description?: string;
}

const { title, slug, publishDate, image, description } = Astro.props;
---

<article class="border-b border-zinc-700 pb-6 mb-6 last:border-0">
	<a href={`/news/${slug}`} class="flex flex-col sm:flex-row gap-4 p-2 hover:bg-zinc-900 group transition-colors duration-200">
		<img
			src={image.src}
			alt={image.alt}
			class="w-full sm:w-64 aspect-video sm:aspect-auto object-cover flex-shrink-0 opacity-90 group-hover:opacity-100 transition-opacity duration-200"
		/>
		<div class="flex-grow flex flex-col justify-center gap-2">
			<time datetime={publishDate.toISOString()} class="text-xs uppercase tracking-widest text-zinc-400 font-light">
				{publishDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })}
			</time>
			<h2 class="text-xl font-montserrat font-bold leading-snug">{title}</h2>
			{description && <p class="text-sm text-zinc-400 font-light leading-relaxed">{description}</p>}
		</div>
	</a>
</article>
